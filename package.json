{
  "name": "@powerfm/libretime-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "tsx watch src/server-client.ts",
    "dev:admin": "tsx watch src/server-admin.ts",
    "build": "tsc",
