# LibreTime instance credentials (required for all servers)
LIBRETIME_URL=https://your-libretime-instance.example.com
LIBRETIME_USER=your_api_username
LIBRETIME_PASS=your_api_password
# Required for file upload — must match general.api_key in LibreTime's config.yml
LIBRETIME_API_KEY=your_libretime_api_key

# API key for HTTP servers (required for server-admin-http and server-client-http)
# Generate one with: npm run generate:key
MCP_API_KEY=your_secret_api_key

# HTTP server port (optional)
# Defaults to 3000 for admin, 3001 for client
MCP_PORT=3000

# Disable API key authentication (optional, development only — never use in production)
# DISABLE_AUTH=true

# Public URL of this MCP server (optional, HTTP admin server only)
# Used by the file upload UI to know where to POST files directly.
# If not set, defaults to http://localhost:<MCP_PORT> — fine for local dev.
# Set this to your public hostname when deploying (e.g. https://mcp.yourstation.com)
MCP_PUBLIC_URL=https://mcp.yourstation.com

# Upload sidecar port (optional, stdio admin server only)
# The stdio server starts a local HTTP endpoint just for file uploads.
# Defaults to 4000. Change if that port is taken on your machine.
# UPLOAD_PORT=4000
